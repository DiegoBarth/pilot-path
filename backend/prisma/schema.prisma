generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

enum StudyType {
  READING
  EXERCISES
  FLASHCARDS
  VIDEO
  SIMULATOR
  MOCK_EXAM
  OTHER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id String @id @default(uuid()) @db.Uuid

  name     String
  email    String @unique
  password String

  googleId String? @unique @map("google_id")

  role UserRole @default(USER)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  enrollments Enrollment[]
  flashcards  UserFlashcard[]
  questions   UserQuestion[]
  mockExams   MockExam[]

  @@map("users")
}

model Certification {
  id String @id @default(uuid()) @db.Uuid

  name String
  slug String @unique

  description String?

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  enrollments Enrollment[]

  subjects CertificationSubject[]

  @@map("certifications")
}

model Subject {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  slug        String  @unique
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  certifications CertificationSubject[]
  flashcards     Flashcard[]
  questions      Question[]
  mockExams      MockExam[]

  @@map("subjects")
}

model CertificationSubject {
  id              String         @id @default(uuid()) @db.Uuid
  certificationId String         @map("certification_id") @db.Uuid
  subjectId       String         @map("subject_id") @db.Uuid
  displayOrder    Int            @default(0) @map("display_order")
  isRequired      Boolean        @default(true) @map("is_required")
  estimatedHours  Int?           @map("estimated_hours")
  certification   Certification  @relation(fields: [certificationId], references: [id])
  subject         Subject        @relation(fields: [subjectId], references: [id])
  studySessions   StudySession[]

  @@unique([certificationId, subjectId])
  @@index([certificationId])
  @@index([subjectId])
  @@map("certification_subjects")
}

model Enrollment {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  certificationId String           @map("certification_id") @db.Uuid
  status          EnrollmentStatus @default(ACTIVE)
  targetExamDate  DateTime?        @map("target_exam_date")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  certification Certification @relation(fields: [certificationId], references: [id])

  studySessions StudySession[]

  @@unique([userId, certificationId])
  @@index([userId])
  @@index([certificationId])
  @@map("enrollments")
}

model StudySession {
  id                     String @id @default(uuid()) @db.Uuid
  enrollmentId           String @map("enrollment_id") @db.Uuid
  certificationSubjectId String @map("certification_subject_id") @db.Uuid

  startedAt DateTime @map("started_at")
  endedAt   DateTime @map("ended_at")

  studyType StudyType @map("study_type")
  notes     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  enrollment           Enrollment           @relation(fields: [enrollmentId], references: [id])
  certificationSubject CertificationSubject @relation(fields: [certificationSubjectId], references: [id])

  @@index([enrollmentId])
  @@index([certificationSubjectId])
  @@index([enrollmentId, startedAt])
  @@map("study_sessions")
}

model Flashcard {
  id String @id @default(uuid()) @db.Uuid

  subjectId String @map("subject_id") @db.Uuid

  question String
  answer   String

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  subject        Subject         @relation(fields: [subjectId], references: [id])
  userFlashcards UserFlashcard[]

  @@unique([subjectId, question])
  @@index([subjectId])
  @@map("flashcards")
}

model UserFlashcard {
  id String @id @default(uuid()) @db.Uuid

  userId      String @map("user_id") @db.Uuid
  flashcardId String @map("flashcard_id") @db.Uuid

  correctCount Int @default(0) @map("correct_count")
  wrongCount   Int @default(0) @map("wrong_count")

  lastReviewedAt DateTime? @map("last_reviewed_at")
  nextReviewAt   DateTime? @map("next_review_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id])

  flashcard Flashcard @relation(fields: [flashcardId], references: [id])

  reviews FlashcardReview[]

  @@unique([userId, flashcardId])
  @@index([userId])
  @@index([flashcardId])
  @@map("user_flashcards")
}

model FlashcardReview {
  id String @id @default(uuid()) @db.Uuid

  userFlashcardId String @map("user_flashcard_id") @db.Uuid

  isCorrect Boolean @map("is_correct")

  reviewedAt DateTime @default(now()) @map("reviewed_at")

  userFlashcard UserFlashcard @relation(fields: [userFlashcardId], references: [id])

  @@index([userFlashcardId])
  @@map("flashcard_reviews")
}

model Question {
  id        String @id @default(uuid()) @db.Uuid
  subjectId String @map("subject_id") @db.Uuid

  statement   String  @db.Text
  explanation String? @db.Text

  difficulty QuestionDifficulty
  isActive   Boolean            @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  subject           Subject               @relation(fields: [subjectId], references: [id])
  alternatives      QuestionAlternative[]
  attempts          UserQuestion[]
  mockExamQuestions MockExamQuestion[]

  @@index([subjectId])
  @@map("questions")
}

model QuestionAlternative {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @map("question_id") @db.Uuid

  letter  String
  content String @db.Text

  isCorrect Boolean @map("is_correct")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  question          Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers           UserQuestion[]
  mockExamQuestions MockExamQuestion[]

  @@index([questionId])
  @@map("question_alternatives")
}

model UserQuestion {
  id String @id @default(uuid()) @db.Uuid

  userId     String @map("user_id") @db.Uuid
  questionId String @map("question_id") @db.Uuid

  selectedAlternativeId String @map("selected_alternative_id") @db.Uuid

  isCorrect Boolean @map("is_correct")

  responseTime Int @map("response_time")

  answeredAt DateTime @default(now()) @map("answered_at")

  user User @relation(fields: [userId], references: [id])

  question Question @relation(fields: [questionId], references: [id])

  selectedAlternative QuestionAlternative @relation(fields: [selectedAlternativeId], references: [id])

  @@index([userId])
  @@index([questionId])
  @@map("user_questions")
}

model MockExam {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  subjectId String? @map("subject_id") @db.Uuid

  score          Int     @default(0)
  totalQuestions Int     @map("total_questions")
  correctAnswers Int     @default(0) @map("correct_answers")
  passingScore   Int     @default(70) @map("passing_score")
  passed         Boolean @default(false)

  duration   Int?      @map("duration")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  user      User               @relation(fields: [userId], references: [id])
  subject   Subject?           @relation(fields: [subjectId], references: [id])
  questions MockExamQuestion[]

  @@index([userId])
  @@index([subjectId])
  @@map("mock_exams")
}

model MockExamQuestion {
  id                    String  @id @default(uuid()) @db.Uuid
  mockExamId            String  @map("mock_exam_id") @db.Uuid
  questionId            String  @map("question_id") @db.Uuid
  selectedAlternativeId String? @map("selected_alternative_id") @db.Uuid

  displayOrder Int      @map("display_order")
  isCorrect    Boolean? @map("is_correct")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mockExam            MockExam             @relation(fields: [mockExamId], references: [id], onDelete: Cascade)
  question            Question             @relation(fields: [questionId], references: [id])
  selectedAlternative QuestionAlternative? @relation(fields: [selectedAlternativeId], references: [id])

  @@unique([mockExamId, questionId])
  @@index([mockExamId])
  @@index([questionId])
  @@map("mock_exam_questions")
}
